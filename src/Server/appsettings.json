{
  "AllowedHosts": "*",

  "MongoDb": {
    "ConnectionString": "mongodb://mongo:27017",
    "DatabaseName": "confer"
  },

  "Jwt": {
    "SecretKey": "CHANGE_ME_USE_ENV_VAR_AT_LEAST_32_CHARS",
    "Issuer": "spqc-confer",
    "Audience": "spqc-confer-clients",
    "ExpiryMinutes": 60
  },

  "LiveKit": {
    "TokenExpiryMinutes": 120
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  }
}
