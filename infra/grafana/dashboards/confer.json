{
  "id": null,
  "uid": "spqc-confer-telemetry",
  "title": "SPQC Confer",
  "description": "Self-hosted chapter meeting platform — local telemetry only, no cloud",
  "tags": ["confer", "self-hosted"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Rooms",
      "description": "Rooms currently in Active state",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "confer_rooms_active",
          "instant": true,
          "legendFormat": "active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rooms Created (1 h)",
      "description": "Rooms created in the last hour",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "increase(confer_rooms_created_total{job=\"confer-server\"}[1h])",
          "instant": true,
          "legendFormat": "created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Auth Failures (5 m)",
      "description": "Failed authentication attempts in the last 5 minutes",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "increase(confer_auth_attempts_total{job=\"confer-server\",result=\"failure\"}[5m])",
          "instant": true,
          "legendFormat": "failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tokens Issued (5 m)",
      "description": "LiveKit room tokens issued in the last 5 minutes",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "increase(confer_tokens_issued_total{job=\"confer-server\"}[5m])",
          "instant": true,
          "legendFormat": "tokens"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "description": "Requests per second across all endpoints",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"confer-server\"}[5m]))",
          "legendFormat": "req/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"confer-server\",http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx/s" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Response Latency",
      "description": "P50 / P95 / P99 response time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{job=\"confer-server\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{job=\"confer-server\"}[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{job=\"confer-server\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LiveKit Token Issuance by Role",
      "description": "Rate of LiveKit room tokens issued, broken out by member role",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "sum(rate(confer_tokens_issued_total{job=\"confer-server\"}[5m])) by (role)",
          "legendFormat": "{{role}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Authentication Attempts",
      "description": "Successful vs failed login attempts per second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "sum(rate(confer_auth_attempts_total{job=\"confer-server\"}[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Room Session Duration",
      "description": "P50 and P95 duration of completed room sessions (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "histogram_quantile(0.50, sum(rate(confer_room_duration_seconds_bucket{job=\"confer-server\"}[30m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "histogram_quantile(0.95, sum(rate(confer_room_duration_seconds_bucket{job=\"confer-server\"}[30m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": ".NET GC Heap Size",
      "description": "Managed heap memory used by the server process",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "spqc-confer-prom" },
          "expr": "process_runtime_dotnet_gc_heap_size_bytes{job=\"confer-server\"}",
          "legendFormat": "heap (bytes)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      }
    }
  ]
}
