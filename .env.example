# Copy to .env and fill in real values — never commit .env to source control

# Required: minimum 32 random characters
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# Optional: restrict to specific chapter subdomain for this node
# CORS_ALLOWED_ORIGINS=https://chapter-a.example.org

# Optional: Grafana admin password (default: changeme — change before exposing to any network)
GRAFANA_ADMIN_PASSWORD=changeme

# Optional: set SEED_ADMIN_EMAIL + SEED_ADMIN_PASSWORD to seed the database on first startup.
# The seeder runs once — if an OrgAdmin already exists it does nothing.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=replace-with-a-strong-password
# SEED_ADMIN_DISPLAY_NAME=Admin
# SEED_CHAPTER_NAME=Default Chapter
# SEED_SFU_URL=wss://your-livekit-node.example.org
# SEED_LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
# SEED_LIVEKIT_API_SECRET=replace-with-livekit-api-secret
